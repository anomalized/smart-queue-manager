# MongoDB Connection URI
# Local dev:
MONGODB_URI=mongodb://127.0.0.1:27017/sqms
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sqms

# Admin authentication password (used for Bearer token)
ADMIN_PASSWORD=admin123

# Server port
PORT=4000

# Frontend API URL (used in production to point to different domain)
REACT_APP_API_URL=http://localhost:4000/api
